# ─────────────────────────────────────────────
#  Task Flow — .gitignore
# ─────────────────────────────────────────────

# Dependencies
node_modules/
**/node_modules/

# Environment variables — NEVER commit these
.env
.env.local
.env.production
.env.production.local
.env.development.local
.env.test.local

# Client production build
client/dist/

# Prisma local SQLite database
server/prisma/dev.db
server/prisma/dev.db-journal
*.db
*.db-journal

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime
pids/
*.pid
*.seed
*.pid.lock

# Coverage
coverage/
*.lcov

# Build
.next/
out/
build/
dist/

# Editor & OS
.DS_Store
Thumbs.db
.vscode/settings.json
.idea/
*.swp
*.swo
