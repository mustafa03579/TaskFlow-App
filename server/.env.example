# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Database ───────────────────────────────────────
# Local SQLite (development)
DATABASE_URL="file:./dev.db"
DB_PROVIDER="sqlite"

# AWS RDS PostgreSQL (production) — uncomment and fill in
# DATABASE_URL="postgresql://USER:PASSWORD@your-rds-endpoint.rds.amazonaws.com:5432/taskflow"
# DB_PROVIDER="postgresql"

# ── Server ─────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Auth (add when implementing JWT) ───────────────
# JWT_SECRET="your-super-secret-key-here"
# JWT_EXPIRES_IN="7d"
